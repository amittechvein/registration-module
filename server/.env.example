# Server
PORT=5000
JWT_SECRET=change-this-secret
PUBLIC_BASE_URL=http://localhost:5173

# Database: sqlite (default, zero-setup) or mysql
DB_DIALECT=sqlite
DB_STORAGE=./registration.sqlite
# For MySQL, set DB_DIALECT=mysql and fill these:
DB_HOST=localhost
DB_PORT=3306
DB_NAME=registration
DB_USER=root
DB_PASS=

# Razorpay (leave empty for mock payment mode in development)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Email notifications (SMTP) — leave empty to log emails to console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="School Admissions <admissions@example.com>"

# SMS via Infobip query API (recommended) — leave empty to log SMS to console
INFOBIP_BASE_URL=https://api.infobip.com
INFOBIP_USERNAME=
INFOBIP_PASSWORD=
INFOBIP_SENDER=TCVEIN
SMS_COUNTRY_CODE=
# OTP SMS text — must match your DLT-registered template ({{otp}} is replaced)
OTP_SMS_TEMPLATE="The one time password for your account is {{otp}}.Please use the password to verify the account. Thanks!TECHVEIN IT SOLUTIONS PVT LTD"

# SMS notifications (MSG91 alternative) — used only if Infobip is not configured
MSG91_AUTH_KEY=
MSG91_SENDER_ID=SCHOOL

# Dev mode: OTP is returned in API response for easy testing (set false in production)
DEV_SHOW_OTP=true
